{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Business Blueprint Skill Run Rubric",
  "type": "object",
  "required": ["case_id", "overall_pass", "score", "checks", "summary"],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string"
    },
    "overall_pass": {
      "type": "boolean"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "checks": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "pass", "score", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "pass": {
            "type": "boolean"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
